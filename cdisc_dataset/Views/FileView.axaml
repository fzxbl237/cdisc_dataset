<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="cdisc_dataset.Views.FileView"
    x:DataType="vm:FileViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:antd-icons="https://atomui.net/icons/antdesign"
    xmlns:atom="https://atomui.net"
    xmlns:converters="using:cdisc_dataset.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:cdisc_dataset.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid RowDefinitions="50,*">
        <DockPanel>
            <atom:ComboBox
                DockPanel.Dock="Left"
                ItemsSource="{Binding FileTypes}"
                MinWidth="180"
                SelectedItem="{Binding SelectedFileType}" />
            <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
                <atom:Button
                    ButtonType="Primary"
                    Command="{Binding LoadStandardSdtmDatasetsCommand}"
                    Content="读取SDTM"
                    Icon="{antd-icons:AntDesignIconProvider Kind=DatabaseOutlined}" />
                <atom:Button
                    ButtonType="Primary"
                    Command="{Binding UploadCommand}"
                    Content="上传文件"
                    Icon="{antd-icons:AntDesignIconProvider Kind=UploadOutlined}" />
            </StackPanel>
        </DockPanel>

        <atom:DataGrid
            CanUserResizeColumns="True"
            CanUserSortColumns="True"
            Grid.Row="1"
            GridLinesVisibility="Horizontal"
            HeadersVisibility="Column"
            HorizontalScrollBarVisibility="Visible"
            IsReadOnly="True"
            ItemsSource="{Binding Files}">
            <atom:DataGrid.Styles>
                <Style Selector="atom|TextBlock">
                    <Setter Property="TextWrapping" Value="Wrap" />
                </Style>
            </atom:DataGrid.Styles>
            <atom:DataGrid.Columns>
                <atom:DataGridTextColumn
                    Binding="{Binding FileName}"
                    Header="File Name"
                    Width="260" />
                <atom:DataGridTemplateColumn Header="Type" Width="140">
                    <atom:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <atom:Tag
                                Foreground="White"
                                Padding="10,4"
                                TagColor="{Binding FileType, Converter={x:Static converters:FileTypeColorConverter.Instance}}"
                                Text="{Binding FileType}" />
                        </DataTemplate>
                    </atom:DataGridTemplateColumn.CellTemplate>
                </atom:DataGridTemplateColumn>
                <!--  <atom:DataGridTextColumn  -->
                <!--  Binding="{Binding ContentType}"  -->
                <!--  Header="Content Type"  -->
                <!--  Width="180" />  -->
                <atom:DataGridTextColumn
                    Binding="{Binding Size}"
                    Header="Size"
                    Width="120" />
                <atom:DataGridTextColumn
                    Binding="{Binding UploadedAt}"
                    Header="Uploaded At"
                    Width="180" />
                <atom:DataGridTemplateColumn Header="Options" Width="120">
                    <atom:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel
                                HorizontalAlignment="Left"
                                Orientation="Horizontal"
                                Spacing="15">
                                <atom:PopupConfirm Title="Sure to delete?">
                                    <Interaction.Behaviors>
                                        <EventTriggerBehavior EventName="Confirmed">
                                            <InvokeCommandAction Command="{Binding $parent[atom:DataGrid].((vm:FileViewModel)DataContext).DeleteCommand}" CommandParameter="{Binding}" />
                                        </EventTriggerBehavior>
                                    </Interaction.Behaviors>
                                    <atom:Button
                                        ButtonType="Link"
                                        Content="Delete"
                                        Icon="{antd-icons:AntDesignIconProvider Kind=DeleteOutlined}" />
                                </atom:PopupConfirm>
                            </StackPanel>
                        </DataTemplate>
                    </atom:DataGridTemplateColumn.CellTemplate>
                </atom:DataGridTemplateColumn>
            </atom:DataGrid.Columns>
        </atom:DataGrid>
    </Grid>
</UserControl>
