<UserControl
    d:DesignHeight="650"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="cdisc_dataset.Views.Dialogs.ProjectDialog"
    x:DataType="vm:EditProjectViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:atom="https://atomui.net"
    xmlns:converter="using:cdisc_dataset.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:cdisc_dataset.ViewModels.Dialogs"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <converter:EnumDescriptionConverter x:Key="EnumDescriptionConverter" />
    </UserControl.Resources>
    <StackPanel
        Margin="20"
        MinWidth="700"
        Spacing="15">
        <atom:TextBlock
            FontSize="18"
            FontWeight="Bold"
            HorizontalAlignment="Left"
            Text="{Binding Title}" />

        <atom:Form
            HorizontalAlignment="Stretch"
            LabelColInfo="4*"
            WrapperColInfo="17*">
            <Interaction.Behaviors>
                <EventTriggerBehavior EventName="Submitted">
                    <InvokeCommandAction Command="{Binding ConfirmCommand}" />
                </EventTriggerBehavior>
            </Interaction.Behaviors>
            <atom:FormItem
                FieldName="ProjectCode"
                IsRequired="True"
                IsValidateFeedbackEnabled="True"
                LabelText="项目号"
                ValidateTrigger="OnChanged"
                Validators="{Binding Validators}">
                <atom:LineEdit
                    IsEnabled="{Binding IsNotEditMode}"
                    PlaceholderText="请输入项目编号"
                    Text="{Binding Project.ProjectCode, Mode=TwoWay}" />
            </atom:FormItem>
            <atom:FormItem
                FieldName="ProtocolCode"
                IsRequired="True"
                IsValidateFeedbackEnabled="True"
                LabelText="项目名称"
                ValidateTrigger="OnChanged"
                Validators="{Binding Validators}">
                <atom:LineEdit PlaceholderText="请输入项目名称" Text="{Binding Project.ProtocolCode, Mode=TwoWay}" />
            </atom:FormItem>
            <atom:FormItem
                FieldName="ProtocolDescription"
                IsRequired="True"
                IsValidateFeedbackEnabled="True"
                LabelText="项目描述"
                ValidateTrigger="OnChanged"
                Validators="{Binding Validators}">
                <atom:TextArea
                    Lines="4"
                    PlaceholderText="请输入项目描述"
                    Text="{Binding Project.ProtocolDescription, Mode=TwoWay}" />
            </atom:FormItem>
            <atom:FormItem
                FieldName="DrugCode"
                IsRequired="True"
                IsValidateFeedbackEnabled="True"
                LabelText="药物号"
                ValidateTrigger="OnChanged"
                Validators="{Binding Validators}">
                <atom:LineEdit PlaceholderText="请输入药物号" Text="{Binding Project.DrugCode, Mode=TwoWay}" />
            </atom:FormItem>
            <atom:FormItem
                FieldName="SdtmIgVersion"
                LabelText="SDTM IG 版本"
                ValidateTrigger="OnChanged"
                Validators="{Binding Validators}">
                <atom:ComboBox ItemsSource="{Binding SdtmIgVersions}" SelectedItem="{Binding Project.SdtmIgVersion, Mode=TwoWay}">
                    <atom:ComboBox.ItemTemplate>
                        <DataTemplate>
                            <atom:TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" />
                        </DataTemplate>
                    </atom:ComboBox.ItemTemplate>
                </atom:ComboBox>
            </atom:FormItem>
            <atom:FormItem
                FieldName="AdamIgVersion"
                LabelText="ADaM IG 版本"
                ValidateTrigger="OnChanged"
                Validators="{Binding Validators}">
                <atom:ComboBox ItemsSource="{Binding AdamIgVersions}" SelectedItem="{Binding Project.AdamIgVersion, Mode=TwoWay}">
                    <atom:ComboBox.ItemTemplate>
                        <DataTemplate>
                            <atom:TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" />
                        </DataTemplate>
                    </atom:ComboBox.ItemTemplate>
                </atom:ComboBox>
            </atom:FormItem>
            <atom:FormItem
                FieldName="Language"
                LabelText="语言"
                ValidateTrigger="OnChanged"
                Validators="{Binding Validators}">
                <atom:ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding Project.Language, Mode=TwoWay}">
                    <atom:ComboBox.ItemTemplate>
                        <DataTemplate>
                            <atom:TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" />
                        </DataTemplate>
                    </atom:ComboBox.ItemTemplate>
                </atom:ComboBox>
            </atom:FormItem>
            <atom:FormActionsItem>
                <StackPanel
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="15">
                    <atom:Button
                        ButtonType="Default"
                        Command="{Binding CancelCommand}"
                        Content="取消" />
                    <atom:SubmitButton Content="确认" />
                </StackPanel>
            </atom:FormActionsItem>
        </atom:Form>
    </StackPanel>
</UserControl>