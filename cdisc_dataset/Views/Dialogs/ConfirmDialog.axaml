<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="cdisc_dataset.Views.Dialogs.ConfirmDialog"
    x:DataType="vm:ConfirmViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:atom="https://atomui.net"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:cdisc_dataset.ViewModels.Dialogs"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="20" MinWidth="420" Spacing="16">
        <TextBlock FontSize="18" FontWeight="Bold" Text="{Binding Title}" />
        <atom:TextBlock Text="{Binding Message}" TextWrapping="Wrap" />
        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="12">
            <atom:Button ButtonType="Default" Command="{Binding CancelCommand}" Content="取消" />
            <atom:Button ButtonType="Primary" Command="{Binding ConfirmCommand}" Content="确认" IsDanger="True" />
        </StackPanel>
    </StackPanel>
</UserControl>
