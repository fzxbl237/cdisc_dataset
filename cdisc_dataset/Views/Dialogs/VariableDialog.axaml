<UserControl
    d:DesignHeight="600"
    d:DesignWidth="1100"
    mc:Ignorable="d"
    x:Class="cdisc_dataset.Views.Dialogs.VariableDialog"
    x:DataType="vm:VariableViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:atom="https://atomui.net"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="clr-namespace:cdisc_dataset.Models"
    xmlns:vm="using:cdisc_dataset.ViewModels.Dialogs"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel
        Margin="20"
        MinWidth="900"
        Spacing="15">
        <atom:TextBlock
            FontSize="18"
            FontWeight="Bold"
            Text="Add Variables" />

        <StackPanel Orientation="Horizontal" Spacing="10">
            <atom:TextBlock Text="Dataset" VerticalAlignment="Center" />
            <atom:ComboBox
                ItemsSource="{Binding DatasetNames}"
                MinWidth="220"
                SelectedItem="{Binding SelectedDatasetName, Mode=TwoWay}" />
        </StackPanel>

        <Grid
            ColumnDefinitions="400,Auto,400"
            ColumnSpacing="15"
            MinHeight="400">
            <DataGrid
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                CanUserSortColumns="False"
                Grid.Column="0"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                ItemsSource="{Binding AvailableVariables}"
                SelectedItem="{Binding SelectedAvailableVariable, Mode=TwoWay}"
                SelectionMode="Single"
                SelectionUnit="FullRow">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Binding="{Binding VariableName}"
                        Header="Variable"
                        Width="120" />
                    <DataGridTextColumn
                        Binding="{Binding Label}"
                        Header="Label"
                        Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Center"
                Spacing="12"
                VerticalAlignment="Center">
                <atom:Button
                    Command="{Binding MoveToRightCommand}"
                    Content="&gt;"
                    MinWidth="56" />
                <atom:Button
                    Command="{Binding MoveToLeftCommand}"
                    Content="&lt;"
                    MinWidth="56" />
            </StackPanel>

            <DataGrid
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                CanUserSortColumns="False"
                Grid.Column="2"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                ItemsSource="{Binding VariablesToAdd}"
                SelectedItem="{Binding SelectedVariableToAdd, Mode=TwoWay}"
                SelectionMode="Single"
                SelectionUnit="FullRow">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Binding="{Binding VariableName}"
                        Header="Variable"
                        Width="120" />
                    <DataGridTextColumn
                        Binding="{Binding Label}"
                        Header="Label"
                        Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <StackPanel
            HorizontalAlignment="Right"
            Orientation="Horizontal"
            Spacing="15">
            <atom:Button
                ButtonType="Default"
                Command="{Binding CancelCommand}"
                Content="取消" />
            <atom:Button
                ButtonType="Primary"
                Command="{Binding SaveCommand}"
                Content="确认" />
        </StackPanel>
    </StackPanel>
</UserControl>
