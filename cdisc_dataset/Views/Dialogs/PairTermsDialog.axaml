<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="cdisc_dataset.Views.Dialogs.PairTermsDialog"
    x:DataType="vm:PairTermsViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:atom="https://atomui.net"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dialogs="using:cdisc_dataset.ViewModels.Dialogs"
    xmlns:formValidator="using:cdisc_dataset.Validations.Form"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:cdisc_dataset.ViewModels.Dialogs"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="20" Spacing="10">
        <atom:TextBlock
            FontSize="18"
            FontWeight="Bold"
            HorizontalAlignment="Left"
            Text="Pair CodeList" />
        <atom:Form
            HorizontalAlignment="Left"
            LabelColInfo="8*"
            Margin="0,0,40,0"
            MinWidth="600"
            WrapperColInfo="16*">
            <Interaction.Behaviors>
                <EventTriggerBehavior EventName="Submitted">
                    <InvokeCommandAction Command="{Binding ConfirmCommand}" />
                </EventTriggerBehavior>
            </Interaction.Behaviors>
            <atom:FormItem
                FieldName="forCodeList"
                IsRequired="True"
                IsValidateFeedbackEnabled="True"
                LabelText="For CodeList"
                ValidateTrigger="OnChanged">
                <atom:FormItem.Validators>
                    <atom:FormValidatorProvider>
                        <atom:FormNotNullValidator Message="Please select for codeList!" />
                    </atom:FormValidatorProvider>
                </atom:FormItem.Validators>
                <atom:Select
                    Filter="{atom:ValueFilterProvider Contains}"
                    FilterValueSelector="{x:Static atom:Select.ValueFilterPropertySelector}"
                    HorizontalAlignment="Stretch"
                    IsAllowClear="True"
                    IsFilterEnabled="True"
                    Mode="Single"
                    OptionsSource="{Binding CodeListOptions}"
                    SelectedOption="{Binding ForCodeListOption, Mode=TwoWay}">
                    <atom:Select.OptionTemplate>
                        <DataTemplate>
                            <StackPanel Spacing="10" x:DataType="dialogs:CodeListSelectOption">
                                <atom:TextBlock Text="{Binding CodeListUniqueId}" />
                                <atom:TextBlock
                                    FontSize="13"
                                    Foreground="#5C9FF9"
                                    Text="{Binding Name}" />
                            </StackPanel>
                        </DataTemplate>
                    </atom:Select.OptionTemplate>
                </atom:Select>
            </atom:FormItem>
            <atom:FormItem
                FieldName="withCodeList"
                IsRequired="True"
                IsValidateFeedbackEnabled="True"
                LabelText="With CodeList"
                ValidateTrigger="OnChanged"
                Validators="{Binding Validators}">
                <atom:Select
                    Filter="{atom:ValueFilterProvider Contains}"
                    FilterValueSelector="{x:Static atom:Select.ValueFilterPropertySelector}"
                    HorizontalAlignment="Stretch"
                    IsAllowClear="True"
                    IsFilterEnabled="True"
                    Mode="Single"
                    OptionsSource="{Binding CodeListOptions}"
                    SelectedOption="{Binding WithCodeListOption, Mode=TwoWay}">
                    <atom:Select.OptionTemplate>
                        <DataTemplate>
                            <StackPanel Spacing="10" x:DataType="dialogs:CodeListSelectOption">
                                <atom:TextBlock Text="{Binding CodeListUniqueId}" />
                                <atom:TextBlock
                                    FontSize="13"
                                    Foreground="#5C9FF9"
                                    Text="{Binding Name}" />
                            </StackPanel>
                        </DataTemplate>
                    </atom:Select.OptionTemplate>
                </atom:Select>
            </atom:FormItem>
            <atom:FormActionsItem>
                <StackPanel
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="10">
                    <atom:Button
                        ButtonType="Default"
                        Command="{Binding CancelCommand}"
                        Content="取消" />
                    <atom:SubmitButton Content="确认" />
                </StackPanel>
            </atom:FormActionsItem>
        </atom:Form>
    </StackPanel>

</UserControl>
