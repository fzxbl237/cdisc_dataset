        <!--  <atom:DataGridTextColumn  -->
        <!--  Binding="{Binding Code}"  -->
        <!--  Header="CodeList"  -->
        <!--  Width="150" />  -->
        <!--  <atom:DataGridTextColumn  -->
        <!--  Binding="{Binding Extensible}"  -->
        <!--  Header="Extensible"  -->
        <!--  Width="120" />  -->
        <!--  <atom:DataGridTextColumn  -->
        <!--  Binding="{Binding Name}"  -->
        <!--  Header="Name"  -->
        <!--  Width="300" />  -->
        <!--  <atom:DataGridTextColumn  -->
        <!--  Binding="{Binding UniqueId}"  -->
        <!--  Header="Submission Value"  -->
        <!--  Width="200" />  -->
        <!--  <atom:DataGridTextColumn  -->
        <!--  Binding="{Binding Synonyms}"  -->
        <!--  Header="Synonyms"  -->
        <!--  Width="400" />  -->
        <!--  <atom:DataGridTextColumn  -->
        <!--  Binding="{Binding Definitions}"  -->
        <!--  Header="Definitions"  -->
        <!--  Width="400" />  -->
        <!--  <atom:DataGridTextColumn  -->
        <!--  Binding="{Binding PreferredTerm}"  -->
        <!--  Header="NCI Preferred Term"  -->
        <!--  Width="400" />  -->
        <!--    -->
        <!--  <atom:DataGridTextColumn  -->
        <!--  Binding="{Binding Terminology}"  -->
